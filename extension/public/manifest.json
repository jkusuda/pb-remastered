{
    "manifest_version": 3,
    "name": "Pokebrowser",
    "version": "1.0",
    "permissions": [
        "storage"
    ],
    "host_permissions": [
        "http://localhost:3000/*"
    ],
    "background": {
        "service_worker": "assets/background.js",
        "type": "module"
    },
    "content_scripts": [
        {
            "matches": ["http://localhost:3000/*"],
            "js": ["assets/content.js"],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}